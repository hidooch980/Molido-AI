generator client {

provider = "prisma-client-js"

}


datasource db {

provider = "postgresql"

url      = env("DATABASE_URL")

}


enum UserRole {

SUPER_ADMIN

ADMIN

MANAGER

ACCOUNTANT

CASHIER

SALES

INVENTORY

EMPLOYEE

CUSTOMER

}


enum UserStatus {

ACTIVE

INACTIVE

SUSPENDED

}


model User {

id          String      @id @default(cuid())


firstName   String

lastName    String


email       String      @unique

phone       String?     @unique


password    String


role        UserRole    @default(EMPLOYEE)

status      UserStatus  @default(ACTIVE)


avatar      String?


companyId   String?

company     Company?    @relation(fields: [companyId], references: [id])


sales       Sale[]


createdAt   DateTime    @default(now())

updatedAt   DateTime    @updatedAt


@@index([companyId])

}


model Company {

id          String       @id @default(cuid())


name        String

legalName   String?


phone       String?

email       String?

website     String?


country     String?

city        String?

address     String?


taxNumber   String?

logo        String?


users       User[]

branches    Branch[]


customers   Customer[]

suppliers   Supplier[]


warehouses  Warehouse[]


categories  Category[]

products    Product[]


purchases   Purchase[]

sales       Sale[]


cashBoxes   CashBox[]


expenses    Expense[]

accounts    Account[]


buildingPermits    BuildingPermit[]

buildingViolations BuildingViolation[]


fireStations       FireStation[]

fireIncidents      FireIncident[]

safetyInspections  SafetyInspection[]


complaints         CitizenComplaint[]

municipalBills     MunicipalBill[]

cheques            Cheque[]

attachments        Attachment[]

posTerminals       PosTerminal[]

treasuryAccounts     TreasuryAccount[]

treasuryTransactions TreasuryTransaction[]

contracts            Contract[]

employees            Employee[]

payrollSlips         PayrollSlip[]

budgets              Budget[]
assets               Asset[]
tenders              Tender[]
attendanceRecords    AttendanceRecord[]
leaveRequests        LeaveRequest[]
performanceReviews   PerformanceReview[]
constructionProjects ConstructionProject[]
fleetVehicles        FleetVehicle[]
serviceZones         ServiceZone[]
letters              Letter[]
loyaltyAccounts      LoyaltyAccount[]
coupons              Coupon[]
salesOrders          SalesOrder[]
approvalRequests     ApprovalRequest[]
citizenProfiles      CitizenProfile[]
cityServiceRequests  CityServiceRequest[]
cityAnnouncements    CityAnnouncement[]
cemeteries           Cemetery[]
burialPermits        BurialPermit[]
taxiDrivers          TaxiDriver[]
businessLicenses     BusinessLicense[]
municipalProperties  MunicipalProperty[]
propertyAudits       PropertyAudit[]
crisisEvents         CrisisEvent[]
parkingLots          ParkingLot[]
streetLights         StreetLight[]
councilMeetings      CouncilMeeting[]
helpTickets          HelpTicket[]
trainingCourses      TrainingCourse[]
documentFolders      DocumentFolder[]
appointments         Appointment[]
surveys              Survey[]
auditLogs            AuditLog[]
clinicRecords        ClinicRecord[]
iotSensors           IotSensor[]
cctv                 CctvCamera[]
utilityMeters        UtilityMeter[]
newsPosts            NewsPost[]
loans                Loan[]
investments          Investment[]
webhooks             Webhook[]
productReturns       ProductReturn[]
shipments            Shipment[]
serialNumbers        SerialNumber[]
batchNumbers         BatchNumber[]
priceLevels          PriceLevel[]
discountRules        DiscountRule[]
projects             Project[]
salesAgents          SalesAgent[]
quotations           Quotation[]
customerTickets      CustomerTicket[]
emailCampaigns       EmailCampaign[]
apiKeys              ApiKey[]
healthChecks         HealthCheckLog[]
diningTables         DiningTable[]
menuCategories       MenuCategory[]
menuItems            MenuItem[]
restaurantOrders     RestaurantOrder[]
tableReservations    TableReservation[]


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt

}


model Branch {

id          String   @id @default(cuid())


companyId   String

company     Company  @relation(fields:[companyId], references:[id], onDelete:Cascade)


name        String

code        String   @unique


phone       String?

email       String?

address     String?


isActive    Boolean  @default(true)


warehouses  Warehouse[]


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt

}


model Customer {

id            String   @id @default(cuid())


companyId     String

company       Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


firstName     String

lastName      String?


phone         String?

email         String?


nationalCode  String?

address       String?


creditLimit   Decimal @default(0) @db.Decimal(18,2)


isActive      Boolean @default(true)


sales         Sale[]
loyaltyAccount LoyaltyAccount?
salesOrders    SalesOrder[]
appointments   Appointment[]
customerTickets CustomerTicket[]


createdAt     DateTime @default(now())

updatedAt     DateTime @updatedAt

}


model Supplier {

id          String @id @default(cuid())


companyId   String

company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


name        String


phone       String?

email       String?

address     String?


isActive    Boolean @default(true)


purchases   Purchase[]


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt

}

model Warehouse {

id          String @id @default(cuid())


companyId   String

company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


branchId    String?

branch      Branch? @relation(fields:[branchId], references:[id])


name        String

code        String @unique


description String?


inventories Inventory[]


purchases   Purchase[]

sales       Sale[]


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt


@@index([companyId])

}


enum ProductStatus {

ACTIVE

INACTIVE

OUT_OF_STOCK

}


enum InventoryTransactionType {

PURCHASE

SALE

RETURN

TRANSFER

ADJUSTMENT

}


model Category {

id          String @id @default(cuid())


companyId   String

company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


name        String

description String?


parentId    String?


parent      Category? @relation("CategoryTree", fields:[parentId], references:[id])

children    Category[] @relation("CategoryTree")


products    Product[]


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt


@@index([companyId])

}


model Product {
  salesOrderItems SalesOrderItem[]
  serialNumbers   SerialNumber[]
  batchNumbers    BatchNumber[]
  productPrices   ProductPrice[]
  quotationItems  QuotationItem[]

id             String @id @default(cuid())


companyId      String

company        Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


categoryId     String?

category       Category? @relation(fields:[categoryId], references:[id])


name           String


sku            String

barcode        String?


description    String?


purchasePrice  Decimal @db.Decimal(18,2)


salePrice      Decimal @db.Decimal(18,2)


taxRate        Decimal? @db.Decimal(5,2)


unit           String


status         ProductStatus @default(ACTIVE)


trackInventory Boolean @default(true)


minStock       Decimal @default(5) @db.Decimal(18,3)


expiryDate     DateTime?


variants       ProductVariant[]


inventories    Inventory[]


purchaseItems  PurchaseItem[]


saleItems      SaleItem[]


createdAt      DateTime @default(now())

updatedAt      DateTime @updatedAt


@@unique([companyId, sku])

@@index([companyId])

}


model ProductVariant {


id          String @id @default(cuid())


productId   String


product     Product @relation(fields:[productId], references:[id], onDelete:Cascade)


name        String


sku         String?


barcode     String?


price       Decimal? @db.Decimal(18,2)


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt

}


model Inventory {


id          String @id @default(cuid())


warehouseId String


warehouse   Warehouse @relation(fields:[warehouseId], references:[id], onDelete:Cascade)


productId   String


product     Product @relation(fields:[productId], references:[id], onDelete:Cascade)


quantity    Decimal @default(0) @db.Decimal(18,3)


createdAt   DateTime @default(now())


updatedAt   DateTime @updatedAt


@@unique([warehouseId, productId])

}

enum PurchaseStatus {

DRAFT

PENDING

APPROVED

RECEIVED

CANCELLED

}


model Purchase {


id            String @id @default(cuid())


companyId     String


company       Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


supplierId    String


supplier      Supplier @relation(fields:[supplierId], references:[id])


warehouseId   String


warehouse     Warehouse @relation(fields:[warehouseId], references:[id])


purchaseNo    String


status        PurchaseStatus @default(DRAFT)


subtotal      Decimal @db.Decimal(18,2)


discount      Decimal @default(0) @db.Decimal(18,2)


tax           Decimal @default(0) @db.Decimal(18,2)


total         Decimal @db.Decimal(18,2)


items         PurchaseItem[]


note          String?


createdAt     DateTime @default(now())


updatedAt     DateTime @updatedAt


@@index([companyId])

}


model PurchaseItem {


id            String @id @default(cuid())


purchaseId    String


purchase      Purchase @relation(fields:[purchaseId], references:[id], onDelete:Cascade)


productId     String


product       Product @relation(fields:[productId], references:[id])


quantity      Decimal @db.Decimal(18,3)


purchasePrice Decimal @db.Decimal(18,2)


total         Decimal @db.Decimal(18,2)


createdAt     DateTime @default(now())

}


enum SaleStatus {


DRAFT


PENDING


PAID


PARTIAL


CANCELLED


RETURNED


}


model Sale {


id            String @id @default(cuid())


companyId     String


company       Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


customerId    String?


customer      Customer? @relation(fields:[customerId], references:[id])


userId        String


user          User @relation(fields:[userId], references:[id])


warehouseId   String


warehouse     Warehouse @relation(fields:[warehouseId], references:[id])


invoiceNo     String


status        SaleStatus @default(DRAFT)


subtotal      Decimal @db.Decimal(18,2)


discount      Decimal @default(0) @db.Decimal(18,2)


tax           Decimal @default(0) @db.Decimal(18,2)


total         Decimal @db.Decimal(18,2)


items         SaleItem[]


payments      Payment[]


installments  Installment[]

cheques       Cheque[]


note          String?


createdAt     DateTime @default(now())


updatedAt     DateTime @updatedAt


@@index([companyId])


}


model SaleItem {


id          String @id @default(cuid())


saleId      String


sale        Sale @relation(fields:[saleId], references:[id], onDelete:Cascade)


productId   String


product     Product @relation(fields:[productId], references:[id])


quantity    Decimal @db.Decimal(18,3)


price       Decimal @db.Decimal(18,2)


discount    Decimal @default(0) @db.Decimal(18,2)


total       Decimal @db.Decimal(18,2)


createdAt   DateTime @default(now())


}

enum PaymentMethod {

CASH

CARD

BANK_TRANSFER

CHEQUE

ONLINE

WALLET

}


enum PaymentStatus {

PENDING

COMPLETED

FAILED

CANCELLED

}


model CashBox {


id          String @id @default(cuid())


companyId   String


company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


name        String


code        String @unique


balance     Decimal @default(0) @db.Decimal(18,2)


payments    Payment[]


createdAt   DateTime @default(now())


updatedAt   DateTime @updatedAt


@@index([companyId])



  posTerminals PosTerminal[]
}


model Payment {


id            String @id @default(cuid())


saleId        String?


sale          Sale? @relation(fields:[saleId], references:[id], onDelete:SetNull)


cashBoxId     String?


cashBox       CashBox? @relation(fields:[cashBoxId], references:[id], onDelete:SetNull)


method        PaymentMethod


status        PaymentStatus @default(PENDING)


amount        Decimal @db.Decimal(18,2)


referenceNo   String?


note          String?


createdAt     DateTime @default(now())


updatedAt     DateTime @updatedAt


@@index([saleId])


}


enum ExpenseStatus {


DRAFT


PAID


CANCELLED


}


model Expense {


id          String @id @default(cuid())


companyId   String


company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


title       String


amount      Decimal @db.Decimal(18,2)


status      ExpenseStatus @default(DRAFT)


note        String?


createdAt   DateTime @default(now())


updatedAt   DateTime @updatedAt


@@index([companyId])


}



enum AccountType {

ASSET

LIABILITY

EQUITY

INCOME

EXPENSE

}


model Account {

id          String @id @default(cuid())


companyId   String

company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


name        String

code        String @unique


type        AccountType


balance     Decimal @default(0) @db.Decimal(18,2)


isActive    Boolean @default(true)


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt


@@index([companyId])

}


// ==========================================
// Technical Office (دفتر فنی شهرداری)
// ==========================================


enum PermitType {

CONSTRUCTION

RENOVATION

DEMOLITION

EXTENSION

}


enum PermitStatus {

PENDING

UNDER_REVIEW

APPROVED

REJECTED

EXPIRED

}


model BuildingPermit {

id          String @id @default(cuid())


companyId   String

company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


permitNo    String @unique


type        PermitType @default(CONSTRUCTION)

status      PermitStatus @default(PENDING)


ownerName   String

ownerPhone  String?

nationalCode String?


address     String

plateNumber String?


area        Decimal @default(0) @db.Decimal(18,2)

floors      Int @default(1)


description String?

rejectReason String?


issuedAt    DateTime?

expiresAt   DateTime?


inspections TechnicalInspection[]

bills       MunicipalBill[]


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt


@@index([companyId])

@@index([status])

}


enum InspectionResult {

PASSED

FAILED

NEEDS_REWORK

}


model TechnicalInspection {

id          String @id @default(cuid())


permitId    String

permit      BuildingPermit @relation(fields:[permitId], references:[id], onDelete:Cascade)


inspectorName String


result      InspectionResult


notes       String?


inspectedAt DateTime @default(now())


createdAt   DateTime @default(now())


@@index([permitId])

}


enum ViolationStatus {

REPORTED

UNDER_REVIEW

FINED

RESOLVED

DISMISSED

}


model BuildingViolation {

id          String @id @default(cuid())


companyId   String

company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


caseNo      String @unique


ownerName   String

address     String


description String


status      ViolationStatus @default(REPORTED)


fineAmount  Decimal? @db.Decimal(18,2)


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt


@@index([companyId])

@@index([status])

}


// ==========================================
// Fire Department (مدیریت آتش‌نشانی)
// ==========================================


model FireStation {

id          String @id @default(cuid())


companyId   String

company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


name        String

code        String @unique


address     String?

phone       String?


firefighters FireFighter[]

vehicles    FireVehicle[]

incidents   FireIncident[]


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt


@@index([companyId])

}


enum FireFighterRank {

CHIEF

DEPUTY_CHIEF

CAPTAIN

LIEUTENANT

FIREFIGHTER

DRIVER

OPERATOR

}


model FireFighter {

id          String @id @default(cuid())


stationId   String

station     FireStation @relation(fields:[stationId], references:[id], onDelete:Cascade)


firstName   String

lastName    String


rank        FireFighterRank @default(FIREFIGHTER)


phone       String?

nationalCode String?


isOnDuty    Boolean @default(false)

isActive    Boolean @default(true)


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt


@@index([stationId])

}


enum FireVehicleStatus {

READY

IN_MISSION

MAINTENANCE

OUT_OF_SERVICE

}


model FireVehicle {

id          String @id @default(cuid())


stationId   String

station     FireStation @relation(fields:[stationId], references:[id], onDelete:Cascade)


name        String

plateNo     String @unique


vehicleType String


status      FireVehicleStatus @default(READY)


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt


@@index([stationId])

}


enum IncidentType {

FIRE

RESCUE

ACCIDENT

FLOOD

HAZMAT

FALSE_ALARM

OTHER

}


enum IncidentStatus {

REPORTED

DISPATCHED

ON_SCENE

CONTAINED

RESOLVED

CANCELLED

}


model FireIncident {

id          String @id @default(cuid())


companyId   String

company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


stationId   String?

station     FireStation? @relation(fields:[stationId], references:[id])


incidentNo  String @unique


type        IncidentType @default(FIRE)

status      IncidentStatus @default(REPORTED)


address     String


reporterName  String?

reporterPhone String?


description String?


casualties  Int @default(0)

injuries    Int @default(0)


reportedAt   DateTime @default(now())

dispatchedAt DateTime?

resolvedAt   DateTime?


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt


@@index([companyId])

@@index([stationId])

@@index([status])

}


enum SafetyResult {

PASSED

FAILED

CONDITIONAL

}


model SafetyInspection {

id          String @id @default(cuid())


companyId   String

company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


propertyName String

address      String


ownerName   String

ownerPhone  String?


result      SafetyResult


certificateNo String? @unique

validUntil    DateTime?


notes       String?


inspectedAt DateTime @default(now())


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt


@@index([companyId])

@@index([result])

}


// ==========================================
// سامانه ۱۳۷ (Citizen Complaints)
// ==========================================


enum ComplaintCategory {

ROADS

WASTE

GREEN_SPACE

LIGHTING

WATER_SEWAGE

CONSTRUCTION

TRAFFIC

OTHER

}


enum ComplaintStatus {

REGISTERED

REFERRED

IN_PROGRESS

RESOLVED

CLOSED

REJECTED

}


model CitizenComplaint {

id          String @id @default(cuid())


companyId   String

company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


trackingNo  String @unique


category    ComplaintCategory @default(OTHER)

status      ComplaintStatus @default(REGISTERED)


citizenName  String?

citizenPhone String?


address     String?


subject     String

description String?


referredTo   String?

responseNote String?


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt


@@index([companyId])

@@index([status])

}


// ==========================================
// عوارض و درآمد شهرداری (Municipal Bills)
// ==========================================


enum MunicipalBillType {

NOSAZI

KASB

PERMIT_FEE

VIOLATION_FINE

OTHER

}


enum MunicipalBillStatus {

UNPAID

PAID

CANCELLED

}


model MunicipalBill {

id          String @id @default(cuid())


companyId   String

company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


billNo      String @unique


type        MunicipalBillType @default(OTHER)

status      MunicipalBillStatus @default(UNPAID)


payerName   String

payerPhone  String?


address     String?


amount      Decimal @db.Decimal(18,2)


description String?


permitId    String?

permit      BuildingPermit? @relation(fields:[permitId], references:[id])


paidAt      DateTime?


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt


@@index([companyId])

@@index([status])

}


// ==========================================
// چک (Cheques)
// ==========================================


enum ChequeType {

RECEIVED

ISSUED

}


enum ChequeStatus {

REGISTERED

DEPOSITED

CLEARED

BOUNCED

RETURNED

}


model Cheque {

id          String @id @default(cuid())


companyId   String

company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


saleId      String?

sale        Sale? @relation(fields:[saleId], references:[id])


chequeNo    String

bankName    String?


dueDate     DateTime


amount      Decimal @db.Decimal(18,2)


type        ChequeType @default(RECEIVED)

status      ChequeStatus @default(REGISTERED)


ownerName   String?

note        String?


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt


@@index([companyId])

@@index([status])

@@index([dueDate])

}


// ==========================================
// اقساط (Installments)
// ==========================================


enum InstallmentStatus {

PENDING

PAID

OVERDUE

}


model Installment {

id          String @id @default(cuid())


saleId      String

sale        Sale @relation(fields:[saleId], references:[id], onDelete:Cascade)


seq         Int


dueDate     DateTime


amount      Decimal @db.Decimal(18,2)


status      InstallmentStatus @default(PENDING)


paidAt      DateTime?


createdAt   DateTime @default(now())

updatedAt   DateTime @updatedAt


@@index([saleId])

}


// ==========================================
// پیوست‌ها (Attachments)
// ==========================================


model Attachment {

id          String @id @default(cuid())


companyId   String

company     Company @relation(fields:[companyId], references:[id], onDelete:Cascade)


entityType  String

entityId    String


fileName    String

filePath    String


mimeType    String?

size        Int @default(0)


createdAt   DateTime @default(now())


@@index([companyId])

@@index([entityType, entityId])

}


// ==================== کارت‌خوان (POS) ====================

enum PosType {
  FIXED
  MOBILE
}

enum PosStatus {
  ACTIVE
  INACTIVE
  UNDER_REPAIR
  RETURNED
}

model PosTerminal {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  terminalNo String @unique

  serialNo String?

  merchantId String?

  bankName String

  pspName String?

  type PosType @default(FIXED)

  status PosStatus @default(ACTIVE)

  accountNo String?

  iban String?

  holderName String?

  location String?

  simNumber String?

  cashBoxId String?
  cashBox   CashBox? @relation(fields: [cashBoxId], references: [id], onDelete: SetNull)

  installedAt DateTime?

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}


// ==========================================
// خزانه‌داری (Treasury)
// ==========================================

enum TreasuryAccountType {
  BANK
  CASH
  FUND
}

enum TreasuryTxType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_IN
  TRANSFER_OUT
}

model TreasuryAccount {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name String

  type TreasuryAccountType @default(BANK)

  bankName  String?
  accountNo String?
  iban      String?

  balance Decimal @default(0) @db.Decimal(18, 2)

  isActive Boolean @default(true)

  note String?

  transactions TreasuryTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model TreasuryTransaction {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  accountId String
  account   TreasuryAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  type TreasuryTxType

  amount Decimal @db.Decimal(18, 2)

  reference   String?
  description String?

  date DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([accountId])
  @@index([date])
}

// ==========================================
// قراردادها (Contracts)
// ==========================================

enum ContractType {
  PURCHASE
  SALE
  SERVICE
  CONSTRUCTION
  EMPLOYMENT
  RENT
  OTHER
}

enum ContractStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  COMPLETED
  TERMINATED
}

model Contract {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  contractNo String @unique

  title String

  type ContractType @default(SERVICE)

  status ContractStatus @default(DRAFT)

  partyName       String
  partyPhone      String?
  partyNationalId String?

  amount Decimal @default(0) @db.Decimal(18, 2)

  startDate DateTime?
  endDate   DateTime?

  description String?

  payments ContractPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([endDate])
}

model ContractPayment {
  id String @id @default(cuid())

  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  amount Decimal @db.Decimal(18, 2)

  dueDate DateTime

  paidAt DateTime?

  status InstallmentStatus @default(PENDING)

  note String?

  createdAt DateTime @default(now())

  @@index([contractId])
  @@index([dueDate])
}

// ==========================================
// حقوق و دستمزد (Payroll)
// ==========================================

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

model Employee {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

