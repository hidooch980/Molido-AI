# =============================================
# Molido AI — تنظیمات Docker Compose
# کپی کنید: cp .env.example .env
# ⚠️ در production همه رمزها را عوض کنید
# =============================================

# دیتابیس
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=molido_ai

# JWT — حتماً مقدار تصادفی و طولانی بگذارید (مثلاً: openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# CORS — آدرس داشبورد وب
CORS_ORIGIN=http://localhost:3001

# آدرس API برای داشبورد وب
NEXT_PUBLIC_API_URL=http://localhost:3000

# هوش مصنوعی (اختیاری — بدون آن تحلیل داخلی فعال است)
OPENAI_API_KEY=

# پیامک کاوه‌نگار (اختیاری)
SMS_API_KEY=
SMS_SENDER=10008663

# n8n
N8N_USER=admin
N8N_PASSWORD=change_me_n8n_password
N8N_WEBHOOK_SECRET=change_me_webhook_secret
